{
  "name": "inkvoice",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/start.sh",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "prettier": "prettier --write \"**/*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}\" --ignore-unknown",
    "ts": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "epub2": "^3.0.2",
    "jsdom": "^27.4.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hotkeys-hook": "^5.2.3",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "agent-browser": "^0.8.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}": "prettier --write",
    "*.{js,mjs,ts,tsx}": "eslint --fix"
  }
}
