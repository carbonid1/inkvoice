{
  "name": "inkvoice",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/start.sh",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "prettier": "prettier --write \"**/*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}\" --ignore-unknown",
    "ts": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:electron": "playwright test --config playwright.electron.config.ts",
    "prepare": "husky",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest --project=storybook",
    "test:run:storybook": "vitest run --project=storybook",
    "electron:dev": "pnpm run build:electron && electron dist-electron/main.js",
    "electron:build": "./scripts/build-electron.sh",
    "build:electron": "tsup electron/main.ts electron/preload.ts --outDir dist-electron --format cjs --clean --external electron",
    "electron:reinstall": "rm -rf /Applications/InkVoice.app && open dist/InkVoice-1.0.0-arm64.dmg"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@formkit/auto-animate": "^0.9.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "@tanstack/react-virtual": "^3.13.21",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "epub2": "^3.0.2",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hotkeys-hook": "^5.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.1.1",
    "agent-browser": "^0.8.6",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "shadcn": "^4.0.2",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}": "prettier --write",
    "*.{js,mjs,ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "electron",
      "prisma"
    ]
  }
}
