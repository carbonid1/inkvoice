    "@prisma/client": "^7.5.0",
    "@tanstack/react-virtual": "^3.13.21",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "epub2": "^3.0.2",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hotkeys-hook": "^5.2.3",
    "sonner": "^2.0.7",
