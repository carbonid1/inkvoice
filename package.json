{
  "name": "inkvoice",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/start.sh",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "prettier": "prettier --write \"**/*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}\" --ignore-unknown",
    "ts": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:electron": "playwright test --config playwright.electron.config.ts",
    "prepare": "husky",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest --project=storybook",
    "test:run:storybook": "vitest run --project=storybook",
    "electron:dev": "pnpm run build:electron && electron dist-electron/main.js",
    "electron:build": "./scripts/build-electron.sh",
    "build:electron": "tsup electron/main.ts electron/preload.ts --outDir dist-electron --format cjs --clean --external electron",
    "electron:reinstall": "rm -rf /Applications/InkVoice.app && open dist/InkVoice-1.0.0-arm64.dmg"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@carbonid1/design-system": "^3.0.0",
    "@formkit/auto-animate": "^0.9.0",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "epub2": "^3.0.2",
    "jsdom": "^29.0.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-hotkeys-hook": "^5.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@carbonid1/eslint-config": "^0.1.0",
    "@carbonid1/prettier-config": "^0.2.1",
    "@carbonid1/tailwind-config": "^0.4.1",
    "@carbonid1/tsconfig": "^0.2.0",
    "@playwright/cli": "^0.1.5",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.6.0",
    "shadcn": "^4.1.2",
    "storybook": "^10.3.3",
    "tsup": "^8.5.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,css,json,md,mdx,yaml,yml}": "prettier --write",
    "*.{js,mjs,ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "electron",
      "prisma"
    ]
  }
}
