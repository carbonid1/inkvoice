generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Book {
  id              String @id // sanitized filename (existing convention)
  title           String
  author          String
  filename        String
  deletedAt       Int? // Unix timestamp ms, null = active
  totalParagraphs Int? // populated on first parse; null = not yet computed
  totalWords      Int? // populated on first parse; null = not yet computed

  progress  ReadingProgress?
  bookmarks Bookmark[]
}

model ReadingProgress {
  bookId               String @id
  chapter              Int    @default(0)
  paragraph            Int    @default(0)
  paragraphsPerChapter String? // JSON: number[]
  wordsPerChapter      String? // JSON: number[]
  lastReadAt           Int? // Unix timestamp ms
  finishedAt           Int? // Unix timestamp ms, null = not finished
  chapterPositions     String? // JSON: Record<number, number>

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String @id @default(uuid())
  bookId    String
  chapter   Int
  paragraph Int
  preview   String?
  createdAt Int // Unix timestamp ms

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model VoicePreference {
  bookId    String @id // "__global__" for default voice
  voiceName String
}

model VoiceMetadata {
  name        String  @id // slugified directory name
  displayName String
  type        String  // 'app' | 'custom'
  tags        String  @default("[]") // JSON: string[]
  language    String? // ISO 639-1 code (e.g. "en", "ru", "uk"), null = auto-detect
  deletedAt   Int? // Unix timestamp ms, null = active
}

model UserSetting {
  key   String @id
  value String // JSON-encoded value
}

model PregenJob {
  id                  String  @id @default(uuid())
  bookId              String
  voice               String
  status              String  @default("queued")
  totalParagraphs     Int
  completedParagraphs Int     @default(0)
  generatedDurationMs Int     @default(0)
  currentChapter      Int     @default(0)
  currentParagraph    Int     @default(0)
  errorMessage        String?
  createdAt           Int // Unix timestamp ms
  updatedAt           Int // Unix timestamp ms

  @@index([status])
  @@index([bookId])
}
