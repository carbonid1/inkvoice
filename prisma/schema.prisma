generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Book {
  id       String   @id // sanitized filename (existing convention)
  title    String
  author   String
  filename String
  addedAt  DateTime @default(now())

  progress  ReadingProgress?
  bookmarks Bookmark[]
  voice     VoicePreference?
}

model ReadingProgress {
  bookId              String @id
  chapter             Int    @default(0)
  sentence            Int    @default(0)
  totalChapters       Int?
  sentencesPerChapter String? // JSON: number[]
  wordsPerChapter     String? // JSON: number[]
  lastReadAt          Int? // Unix timestamp ms
  chapterPositions    String? // JSON: Record<number, number>

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String @id @default(uuid())
  bookId    String
  chapter   Int
  sentence  Int
  label     String?
  preview   String?
  createdAt Int // Unix timestamp ms

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model VoicePreference {
  bookId    String @id // "__global__" for default voice
  voiceName String

  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model VoiceMetadata {
  name        String @id // slugified directory name
  displayName String
  type        String // 'app' | 'custom'
  tags        String @default("[]") // JSON: string[]
}

model UserSetting {
  key   String @id
  value String // JSON-encoded value
}
